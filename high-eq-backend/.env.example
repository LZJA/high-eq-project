# ========================================
# HighEQ 后端环境变量配置模板
# ========================================
# 复制此文件为 .env 并填入真实的配置值
# 适用于本地开发和 Docker 部署

# ========================================
# 数据库配置（本地开发 + Docker 通用）
# ========================================
# 本地开发: 连接本地 MySQL
# Docker: docker-compose 会使用这些配置创建 MySQL 容器
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here

# Docker 部署专用配置
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=higheq

# 本地开发数据库配置
# MYSQL_HOST=localhost
# MYSQL_PORT=3306

# ========================================
# JWT 安全配置
# ========================================
# 生成强密钥: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-this-in-production-at-least-32-characters-long

# ========================================
# AI 服务配置
# ========================================
# DeepSeek API Key (获取地址: https://platform.deepseek.com/)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ========================================
# 可选配置
# ========================================
# 服务器端口 (默认: 8080)
# SERVER_PORT=8080

# 日志级别 (默认: INFO)
# LOG_LEVEL=DEBUG

# Docker 部署后端端口 (仅用于 docker-compose.prod.yml)
# BACKEND_PORT=8080
