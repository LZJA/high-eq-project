# ========================================
# HighEQ 鍚庣鐜鍙橀噺閰嶇疆妯℃澘
# ========================================
# 澶嶅埗姝ゆ枃浠朵负 .env 骞跺～鍏ョ湡瀹炵殑閰嶇疆鍊?
# 閫傜敤浜庢湰鍦板紑鍙戝拰 Docker 閮ㄧ讲

# ========================================
# 鏁版嵁搴撻厤缃紙鏈湴寮€鍙?+ Docker 閫氱敤锛?
# ========================================
# 鏈湴寮€鍙? 杩炴帴鏈湴 MySQL
# Docker: docker-compose 浼氫娇鐢ㄨ繖浜涢厤缃垱寤?MySQL 瀹瑰櫒
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here

# Docker 閮ㄧ讲涓撶敤閰嶇疆
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=higheq

# 鏈湴寮€鍙戞暟鎹簱閰嶇疆
# MYSQL_HOST=localhost
# MYSQL_PORT=3306

# ========================================
# JWT 瀹夊叏閰嶇疆
# ========================================
# 鐢熸垚寮哄瘑閽? openssl rand -base64 32
JWT_SECRET=your-secret-key-change-this-in-production-at-least-32-characters-long

# ========================================
# AI 鏈嶅姟閰嶇疆
# ========================================
# DeepSeek API Key (鑾峰彇鍦板潃: https://platform.deepseek.com/)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 閫氫箟鍗冮棶 API Key (鑾峰彇鍦板潃: https://dashscope.aliyun.com/)
QWEN_API_KEY=sk-your-qwen-api-key-here

# 璞嗗寘 API Key (鑾峰彇鍦板潃: https://www.doubao.com/)

DOUBAO_MODEL=doubao-seed-1.8
# 可选：如果你在方舟有推理接入点，改成接入点 ID（如 ep-20260311123456-xxxx）
# DOUBAO_MODEL=ep-xxxxxxxx
# DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3

# ========================================
# 阿里云 OSS 配置
# ========================================
ALIYUN_OSS_REGION=oss-cn-hangzhou
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_BUCKET_NAME=your-bucket-name
# 如果你绑定了自定义 CDN/静态域名，填这里；否则可留空使用默认 OSS 域名拼接
ALIYUN_OSS_PUBLIC_URL_BASE=https://your-bucket-name.oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_CHAT_IMAGE_PREFIX=chat-images/
ALIYUN_OSS_ACCESS_KEY_ID=你的AccessKey ID
ALIYUN_OSS_ACCESS_KEY_SECRET=你的AccessKey Secret



# ========================================
# 鍙€夐厤缃?
# ========================================
# 鏈嶅姟鍣ㄧ鍙?(榛樿: 8080)
# SERVER_PORT=8080

# 鏃ュ織绾у埆 (榛樿: INFO)
# LOG_LEVEL=DEBUG

# Docker 閮ㄧ讲鍚庣绔彛 (浠呯敤浜?docker-compose.prod.yml)
# BACKEND_PORT=8080

ALIYUN_OSS_PRESIGN_EXPIRE_SECONDS=300
