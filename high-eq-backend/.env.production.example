# ========================================
# HighEQ 后端生产环境配置模板
# ========================================
# 复制此文件为 .env.production 并填入真实的生产环境配置

# ========================================
# 数据库配置（Docker 生产环境）
# ========================================
# MySQL 用户名
MYSQL_USER=higheq

# MySQL 密码（生产环境必须使用强密码）
MYSQL_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# MySQL Root 密码（生产环境必须使用强密码）
MYSQL_ROOT_PASSWORD=CHANGE_THIS_TO_STRONG_ROOT_PASSWORD

# 数据库名
MYSQL_DATABASE=higheq

# ========================================
# JWT 安全配置
# ========================================
# JWT 密钥（生产环境必须使用强随机密钥）
# 生成命令: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_STRONG_JWT_SECRET_MIN_32_CHARS

# Token 过期时间（毫秒）
# 24 小时
JWT_EXPIRATION=86400000

# Refresh Token 过期时间（毫秒）
# 7 天
JWT_REFRESH_EXPIRATION=604800000

# ========================================
# AI 服务配置
# ========================================
# DeepSeek API Key（生产环境必须填入真实密钥）
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-CHANGE_THIS_TO_REAL_API_KEY

# ========================================
# CORS 配置（可选）
# ========================================
# 允许的前端域名（多个用逗号分隔）
# 如果前后端在同一域名下，可以留空或设置为 .*
# CORS_ALLOWED_ORIGINS=https://higheq.top,https://www.higheq.top

# ========================================
# 服务器配置（可选）
# ========================================
# 服务器端口（默认: 8080）
# SERVER_PORT=8080

# 日志级别（生产环境建议: INFO 或 WARN）
# LOG_LEVEL=INFO

# Spring 激活的配置文件（通常不需要手动设置）
# SPRING_PROFILES_ACTIVE=prod
