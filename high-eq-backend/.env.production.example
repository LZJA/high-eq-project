# ========================================
# HighEQ 鍚庣鐢熶骇鐜閰嶇疆妯℃澘
# ========================================
# 澶嶅埗姝ゆ枃浠朵负 .env.production 骞跺～鍏ョ湡瀹炵殑鐢熶骇鐜閰嶇疆

# ========================================
# 鏁版嵁搴撻厤缃紙Docker 鐢熶骇鐜锛?
# ========================================
# MySQL 鐢ㄦ埛鍚?
MYSQL_USER=higheq

# MySQL 瀵嗙爜锛堢敓浜х幆澧冨繀椤讳娇鐢ㄥ己瀵嗙爜锛?
MYSQL_PASSWORD=CHANGE_THIS_TO_STRONG_PASSWORD

# MySQL Root 瀵嗙爜锛堢敓浜х幆澧冨繀椤讳娇鐢ㄥ己瀵嗙爜锛?
MYSQL_ROOT_PASSWORD=CHANGE_THIS_TO_STRONG_ROOT_PASSWORD

# 鏁版嵁搴撳悕
MYSQL_DATABASE=higheq

# ========================================
# JWT 瀹夊叏閰嶇疆
# ========================================
# JWT 瀵嗛挜锛堢敓浜х幆澧冨繀椤讳娇鐢ㄥ己闅忔満瀵嗛挜锛?
# 鐢熸垚鍛戒护: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_STRONG_JWT_SECRET_MIN_32_CHARS

# Token 杩囨湡鏃堕棿锛堟绉掞級
# 24 灏忔椂
JWT_EXPIRATION=86400000

# Refresh Token 杩囨湡鏃堕棿锛堟绉掞級
# 7 澶?
JWT_REFRESH_EXPIRATION=604800000

# ========================================
# AI 鏈嶅姟閰嶇疆
# ========================================
# DeepSeek API Key锛堢敓浜х幆澧冨繀椤诲～鍏ョ湡瀹炲瘑閽ワ級
# 鑾峰彇鍦板潃: https://platform.deepseek.com/

# Doubao / Ark API 配置（可选，不配则不会启用豆包模型）
DOUBAO_API_KEY=CHANGE_THIS_TO_REAL_DOUBAO_API_KEY
DOUBAO_MODEL=doubao-seed-1.8
# 可选：如果你在方舟有推理接入点，改成接入点 ID（如 ep-xxxxxxxx）
# DOUBAO_MODEL=ep-xxxxxxxx
# DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3


# ========================================
# CORS 閰嶇疆锛堝彲閫夛級
# ========================================
# 鍏佽鐨勫墠绔煙鍚嶏紙澶氫釜鐢ㄩ€楀彿鍒嗛殧锛?
# 濡傛灉鍓嶅悗绔湪鍚屼竴鍩熷悕涓嬶紝鍙互鐣欑┖鎴栬缃负 .*
# CORS_ALLOWED_ORIGINS=https://higheq.top,https://www.higheq.top

# ========================================
# 鏈嶅姟鍣ㄩ厤缃紙鍙€夛級
# ========================================
# 鏈嶅姟鍣ㄧ鍙ｏ紙榛樿: 8080锛?
# SERVER_PORT=8080

# 鏃ュ織绾у埆锛堢敓浜х幆澧冨缓璁? INFO 鎴?WARN锛?
# LOG_LEVEL=INFO

# Spring 婵€娲荤殑閰嶇疆鏂囦欢锛堥€氬父涓嶉渶瑕佹墜鍔ㄨ缃級
# SPRING_PROFILES_ACTIVE=prod

