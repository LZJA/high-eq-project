# 本地开发配置
# 请复制此文件为 application.local.yml 并填入真实值

spring:
  datasource:
    url: jdbc:mysql://localhost:3307/high_eq_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=utf8&useUnicode=true
    username: root
    password: root

jwt:
  secret: local-dev-secret-key-change-in-production-at-least-32-chars
  expiration: 86400000

ai:
  deepseek:
    api-key: sk-your-api-key-here
    api-url: https://api.deepseek.com/v1
    model: deepseek-chat
    temperature: 0.7
    max-tokens: 500
