# ========================================
# HighEQ 前端环境变量配置
# ========================================
# 复制此文件为 .env 并填入真实的配置值

# ========================================
# API 配置
# ========================================
# 后端 API 地址
# 开发环境使用代理: /api
# 生产环境填写完整地址: https://api.example.com
VITE_API_URL=/api

# ========================================
# 可选配置
# ========================================
# 应用标题
# VITE_APP_TITLE=HighEQ

# API 超时时间 (毫秒)
# VITE_API_TIMEOUT=30000
