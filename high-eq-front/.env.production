# ========================================
# HighEQ 前端生产环境配置
# ========================================
# 构建前端时使用此配置

# ========================================
# API 配置
# ========================================
# 生产环境 API 地址
# 生产环境通过前端域名下的 /api 反向代理访问后端，避免浏览器跨域问题
VITE_API_URL=/api

# ========================================
# 应用配置
# ========================================
# 应用标题
VITE_APP_TITLE=高情商回复助手

# API 超时时间 (毫秒)
VITE_API_TIMEOUT=30000
